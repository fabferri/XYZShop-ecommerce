# XYZShop environment configuration
# Copy this file to `.env` and adjust the values. Never commit the real `.env`.

# Secret key used for cryptographic signing. Generate a new one for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-value

# Debug mode. MUST be False in production.
DEBUG=True

# Comma-separated list of hosts/domains this site can serve.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted origins for CSRF (required for HTTPS behind a proxy).
# Example: https://shop.example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=

# --- Production HTTPS hardening (only applied when DEBUG=False) ---
# Redirect HTTP to HTTPS (set to False if TLS is terminated upstream and you don't want a redirect).
SECURE_SSL_REDIRECT=True
# HSTS max-age in seconds. Set to 0 to disable while testing HTTPS.
SECURE_HSTS_SECONDS=31536000
